#!/bin/bash
set -Euo pipefail
##################################################################################################################
# Author    : Erik Dubois
# Website   : https://kiroproject.be
##################################################################################################################
#
#   DO NOT JUST RUN THIS. EXAMINE AND JUDGE. RUN AT YOUR OWN RISK.
#
#   Purpose:
#   Refreshes the pacman database, installs openssh, enables the sshd
#   service, allows SSH through firewalld, and (on the live ISO only)
#   sets a password for the passwordless `liveuser` so sshd's password
#   auth becomes usable.
#
#   Why: SSH isn't enabled by default in the Kiro ISO for security;
#   this is the one-command opt-in for users who want remote access.
#   firewalld's default zone already permits ssh, but allowing it
#   explicitly keeps the opt-in working on hardened or non-default zones.
#   On the live ISO, liveuser ships with no password — without one,
#   sshd's password auth refuses the login even when the daemon is up.
#
#   Standalone: this script vendors the few helpers it needs so it has
#   no dependency on common.sh / kiro-common.sh.
#
##################################################################################################################

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DRY_RUN=false

# ── Colors ──────────────────────────────────────────────────────────────────
# Only enabled when tput is available and output is to a terminal.
if command -v tput >/dev/null 2>&1 && [[ -t 1 ]]; then
    RED="$(tput setaf 1)"
    GREEN="$(tput setaf 2)"
    YELLOW="$(tput setaf 3)"
    BLUE="$(tput setaf 4)"
    CYAN="$(tput setaf 6)"
    RESET="$(tput sgr0)"
    BOLD="$(tput bold)"
else
    RED="" GREEN="" YELLOW="" BLUE="" CYAN="" RESET="" BOLD=""
fi

# ── Logging ───────────────────────────────────────────────────────────────────
log_section() {
    echo
    echo "${GREEN}################################################################################${RESET}"
    echo "${BOLD}${GREEN}$1${RESET}"
    echo "${GREEN}################################################################################${RESET}"
    echo
}

log_subsection() {
    echo
    echo "${CYAN}########################################################################${RESET}"
    echo "${BOLD}${CYAN}$1${RESET}"
    echo "${CYAN}########################################################################${RESET}"
    echo
}

log_info() {
    echo "${BLUE}ℹ ${1}${RESET}"
}

log_success() {
    echo "${GREEN}✓ ${1}${RESET}"
}

# ── Helpers ───────────────────────────────────────────────────────────────────
show_help() {
    local script_name="$1"
    local description="$2"
    local usage="$3"

    cat <<EOF
${BOLD}${GREEN}${script_name}${RESET} - ${description}

${BOLD}Usage:${RESET}
    ${script_name} ${usage}

${BOLD}Options:${RESET}
    -h, --help          Show this help message and exit
    -v, --version       Show version information and exit
    -d, --dry-run       Show what would be done without making changes

${BOLD}Examples:${RESET}
    ${script_name} --help
    ${script_name} --version
    ${script_name} --dry-run
EOF
}

show_version() {
    local script_name="$1"
    local resolved pkg

    resolved="$(realpath "$0" 2>/dev/null || echo "$0")"
    if pkg="$(pacman -Qqo "${resolved}" 2>/dev/null)" && [[ -n "${pkg}" ]]; then
        pacman -Q "${pkg}"
    else
        echo "${script_name} (not installed via pacman)"
    fi
}

# Re-run as root via pkexec (graphical) or sudo (terminal) if not already root.
ensure_root() {
    [[ $EUID -eq 0 ]] && return 0
    local self
    self="$(realpath "${BASH_SOURCE[-1]}")"
    if [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]] && command -v pkexec >/dev/null 2>&1; then
        echo "${YELLOW}$(basename "$self") needs root — requesting your password...${RESET}" >&2
        # pkexec scrubs the environment; pass TERM through to keep colored output.
        exec pkexec env TERM="${TERM:-xterm-256color}" "$self" "$@"
    fi
    echo "${YELLOW}$(basename "$self") needs root — re-running with sudo...${RESET}" >&2
    exec sudo "$self" "$@"
}

# Run a command, or just describe it when DRY_RUN is enabled.
execute_or_dryrun() {
    local description="$1"
    shift
    local cmd=("$@")

    if [[ "${DRY_RUN:-false}" == "true" ]]; then
        log_info "[DRY-RUN] Would execute: ${description}"
        log_info "[DRY-RUN] Command: ${cmd[*]}"
    else
        "${cmd[@]}"
    fi
}

# ── Main ────────────────────────────────────────────────────────────────────
main() {
    for arg in "$@"; do
        case "$arg" in
            -h|--help)
                show_help "$(basename "$0")" \
                    "Install openssh, enable sshd, and allow SSH through the firewall" \
                    "[--help] [--version] [--dry-run]"
                exit 0
                ;;
            -v|--version)
                show_version "$(basename "$0")"
                exit 0
                ;;
            -d|--dry-run)
                DRY_RUN=true
                log_info "Dry-run mode enabled — no changes will be made"
                ;;
            *)
                echo "${RED}Unknown option: $arg${RESET}" >&2
                exit 1
                ;;
        esac
    done

    ensure_root "$@"

    log_section "Enabling SSH"

    log_subsection "Refreshing pacman database"
    # Live ISO ships a seeded /var/lib/pacman/sync/ that may be empty or stale;
    # always refresh first so `pacman -S openssh` succeeds without manual `-Sy`.
    execute_or_dryrun "Refresh pacman database" pacman -Sy --noconfirm

    log_subsection "Installing openssh"
    execute_or_dryrun "Install openssh" pacman -S openssh --noconfirm

    log_subsection "Installing extra packages (bash-completion, obs-studio, samba client)"
    # smbclient browses shares, cifs-utils mounts them, gvfs-smb exposes them
    # to GTK file managers (Files, Thunar, etc.).
    execute_or_dryrun "Install bash-completion, obs-studio and samba client tools" \
        pacman -S bash-completion obs-studio smbclient cifs-utils gvfs-smb --noconfirm --needed

    log_subsection "Enabling and starting sshd"
    execute_or_dryrun "Enable sshd" systemctl enable --now sshd

    log_subsection "Allowing SSH through the firewall"
    if command -v firewall-cmd >/dev/null 2>&1; then
        # firewall-cmd (even --permanent) needs the daemon over D-Bus; when it's
        # not running — e.g. on the live ISO — use firewall-offline-cmd instead.
        if systemctl is-active --quiet firewalld; then
            execute_or_dryrun "Allow ssh service in firewalld (permanent)" \
                firewall-cmd --permanent --add-service=ssh
            execute_or_dryrun "Reload firewalld" firewall-cmd --reload
        elif command -v firewall-offline-cmd >/dev/null 2>&1; then
            log_info "firewalld not running — applying permanent rule offline"
            execute_or_dryrun "Allow ssh service in firewalld (offline)" \
                firewall-offline-cmd --add-service=ssh
        else
            log_info "firewalld not running — nothing is blocking SSH, skipping firewall rule"
        fi
    else
        log_info "firewalld not installed — skipping firewall rule"
    fi

    log_subsection "Setting password to 'erik'"
    # sshd's password auth refuses a login for an account with no password.
    # On the live ISO liveuser ships passwordless; on an installed system the
    # invoking user may also lack a usable password for SSH. Either way, set
    # 'erik' as the password so password auth works. The invoking user is
    # resolved through sudo/pkexec since the script re-runs as root.
    target_user=""
    if [[ -d /run/archiso/bootmnt ]] && id -u liveuser >/dev/null 2>&1; then
        target_user="liveuser"
    elif [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
        target_user="${SUDO_USER}"
    elif [[ -n "${PKEXEC_UID:-}" ]]; then
        target_user="$(id -un "${PKEXEC_UID}" 2>/dev/null || true)"
    fi

    if [[ -n "${target_user}" ]] && id -u "${target_user}" >/dev/null 2>&1; then
        execute_or_dryrun "Set password for '${target_user}' to 'erik'" \
            bash -c "echo '${target_user}:erik' | chpasswd"
    else
        log_info "Could not resolve a user to set a password for — skipping"
    fi

    log_success "$(basename "$0") done"
}

main "$@"
